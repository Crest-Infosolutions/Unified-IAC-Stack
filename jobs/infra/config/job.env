GIT_HOST=github.com
VAULT_GITHUB_TOKEN_PATH=secret/github
LZ_MODULES_REPO=santosh0123456/lz-modules
PACKER_REPO=santosh0123456/packer-images
IMAGE_REGISTRY_REPO=santosh0123456/image-registry
PACKER_TEMPLATE=nginx.pkr.hcl
IMAGE_REGISTRY_FILE=images.json
IMAGE_REGISTRY_KEY=rhel9-base
RUN_PACKER=false
TERRAFORM_ACTION=apply
TF_VAR_ADMIN_USERNAME=azureuser
TF_VAR_SSH_PUBLIC_KEY=ssh-rsa CHANGE_ME
GIT_AUTHOR_EMAIL=pipeline@local
GIT_AUTHOR_NAME=pipeline