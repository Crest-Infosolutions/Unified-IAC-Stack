VAULT_ADDR=http://vault:8200
VAULT_NAMESPACE=tfeplatform
VAULT_INIT_SECRET_NAME=vault-init
VAULT_K8S_HOST=https://kubernetes.default.svc
VAULT_K8S_CA_CERT_PATH=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt
VAULT_K8S_TOKEN_REVIEWER_JWT_PATH=/var/run/secrets/kubernetes.io/serviceaccount/token
VAULT_GITHUB_TOKEN_PATH=secret/github
GITHUB_TOKEN_VALUE=
TFE_SERVICE_ACCOUNT=tfe
TFE_AGENT_SERVICE_ACCOUNT=tfe-agent
INFRA_PIPELINE_SERVICE_ACCOUNT=infra-pipeline
CONFIG_PIPELINE_SERVICE_ACCOUNT=config-pipeline
VAULT_TFE_ROLE=tfe
VAULT_TFE_AGENT_ROLE=tfe-agent
VAULT_INFRA_ROLE=infra-pipeline
VAULT_CONFIG_ROLE=config-pipeline