REGISTRY_NAME=youracrname
REGISTRY_SERVER=youracrname.azurecr.io
BUNDLE_VERSION=0.1.0
MARKETPLACE_PACKAGE_DIR=/absolute/path/to/Unified-IAC-Stack/marketplace/byol-tfe-platform-v1

CPA_IMAGE=mcr.microsoft.com/container-package-app:latest
HELM_RELEASE_NAME=byol-tfe-platform
VALUES_FILE=examples/values.enterprise.example.yaml

# CPA packaging is documented for Linux/Windows AMD64 hosts.
# Set to true only if you intentionally want to attempt the CPA step on an unsupported host.
ALLOW_UNSUPPORTED_HOST=false