TFE_HOSTNAME=tfe.example.corp
TFE_OPERATIONAL_MODE=external
TFE_TLS_CERT_FILE=/etc/ssl/private/terraform-enterprise/cert.pem
TFE_TLS_KEY_FILE=/etc/ssl/private/terraform-enterprise/key.pem
TFE_TLS_CA_BUNDLE_FILE=/etc/ssl/private/terraform-enterprise/bundle.pem
TFE_DATABASE_HOST=postgres.example.corp:5432
TFE_DATABASE_NAME=tfe
TFE_DATABASE_USER=tfe
TFE_DATABASE_PARAMETERS=sslmode=require
TFE_REDIS_URL=redis://redis.example.corp:6379
TFE_OBJECT_STORAGE_TYPE=azure
TFE_OBJECT_STORAGE_AZURE_ACCOUNT_NAME=exampleaccount
TFE_OBJECT_STORAGE_AZURE_CONTAINER=tfestate
TFE_VAULT_ENABLED=true
TFE_VAULT_ADDRESS=https://vault.example.corp:8200
TFE_VAULT_CLUSTER_ADDRESS=https://vault.example.corp:8201
TFE_VAULT_DISABLE_MLOCK=true
TFE_RUN_PIPELINE_MODE=external
TFE_HTTP_PORT=8080
TFE_HTTPS_PORT=8443
TFE_SAML_ENABLED=true
TFE_SAML_METADATA_URL=https://login.microsoftonline.com/tenant-id/federationmetadata/2007-06/federationmetadata.xml
TFE_SAML_CONSUMER_SERVICE_URL=https://tfe.example.corp/users/saml/auth
TFE_SAML_ENTITY_ID=https://tfe.example.corp/users/saml/metadata